<IfModule mod_rewrite.c">
    RewriteEngine On
    RewriteBase /teacher-eval/

    # Handle OPTIONS requests (preflight)
    RewriteCond %{REQUEST_METHOD} ^OPTIONS$ [NC]
    RewriteRule ^(.*)$ - [L]

    # Don't rewrite if it's a real file
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^(.*)$ - [L]
    
    # Don't rewrite if it's a real directory
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.*)$ - [L]
    
    # Route API requests with .php to public_api.php (strip .php and rewrite)
    RewriteRule ^api/([a-zA-Z0-9-]+)\.php(/.*)?$ public_api.php/api/$1$2 [QSA,L]
    
    # Route API requests without .php to public_api.php
    RewriteRule ^api/(.*)$ public_api.php/api/$1 [QSA,L]

    # Route everything else to index.php
    RewriteRule ^(.*)$ index.php?request=$1 [QSA,L]
</IfModule>
