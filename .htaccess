<IfModule mod_rewrite.c">
    RewriteEngine On
    
    # Dynamic RewriteBase - works for both local (/teacher-eval/) and production (/)
    RewriteCond %{HTTP_HOST} ^localhost [NC,OR]
    RewriteCond %{HTTP_HOST} ^127\.0\.0\.1 [NC]
    RewriteRule ^(.*)$ - [E=REWRITE_BASE:/teacher-eval/]
    
    RewriteCond %{ENV:REWRITE_BASE} ^$
    RewriteRule ^(.*)$ - [E=REWRITE_BASE:/]
    
    RewriteBase %{ENV:REWRITE_BASE}

    # Handle OPTIONS requests (preflight)
    RewriteCond %{REQUEST_METHOD} ^OPTIONS$ [NC]
    RewriteRule ^(.*)$ - [L]

    # Don't rewrite if it's a real file
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^(.*)$ - [L]
    
    # Don't rewrite if it's a real directory
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.*)$ - [L]
    
    # Route API requests directly to /api/ directory (files like questions.php, teachers.php, etc)
    # /api/questions -> /api/questions.php
    RewriteRule ^api/([a-zA-Z_-]+)/?$ api/$1.php [QSA,L]
    
    # Route everything else to index.php
    RewriteRule ^(.*)$ index.php?request=$1 [QSA,L]
</IfModule>
