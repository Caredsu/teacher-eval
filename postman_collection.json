        {
          "name": "Submit Evaluation (Anonymous)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teacher_id\": \"{{teacher_id}}\",\n  \"ratings\": {\n    \"teaching\": 5,\n    \"communication\": 4,\n    \"knowledge\": 5\n  },\n  \"feedback\": \"Excellent instruction with clear explanations and engaging teaching methods. The instructor responds well to student questions and makes complex topics easy to understand.\"\n}"
            },
            "url": {
              "raw": "http://localhost/teacher-eval/api/evaluations",
              "protocol": "http",
              "host": ["localhost"],
              "path": ["teacher-eval", "api", "evaluations"]
            }
          }
        },
        {
          "name": "Get Teacher Evaluations",
          "request": {
            "method": "GET",
